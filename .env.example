# AmanQR Environment Configuration
# Copy this file to .env and fill in your actual API keys

# ============================================
# Azure OpenAI Configuration
# ============================================
# Get these from Azure Portal > OpenAI resource > Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================
# Google Safe Browsing Configuration
# ============================================
# Get this from Google Cloud Console > APIs & Services > Credentials
GOOGLE_SAFE_BROWSING_API_KEY=your-google-api-key

# ============================================
# URLhaus Configuration
# ============================================
# No API key required - uses public API endpoint
# Endpoint: https://urlhaus-api.abuse.ch/v1/url/

# ============================================
# Note: Do NOT commit the actual .env file to version control
# This file (.env.example) is safe to commit as a template
