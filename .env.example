# AmanQR Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# Security Proxy Configuration (Required)
# ============================================
# Cloudflare Worker endpoint for security checks
# This proxy keeps API keys secure on the server-side
# Format: https://your-worker.your-subdomain.workers.dev
EXPO_PUBLIC_SECURITY_PROXY_ENDPOINT=https://your-worker.your-subdomain.workers.dev

# ============================================
# Note: Do NOT commit the actual .env file to version control
# This file (.env.example) is safe to commit as a template

# ============================================
# Historical: Azure OpenAI (Deprecated)
# ============================================
# Azure OpenAI was removed in v1.0 Revision 1.1 due to high latency (10-30s)
# Replaced with enhanced local heuristics for instant analysis (<50ms)
# Kept here for historical reference only
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
# AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================
# Historical: Direct API Keys (Deprecated)
# ============================================
# These keys are no longer used in the client
# They are now stored securely in the Cloudflare Worker
# GOOGLE_SAFE_BROWSING_API_KEY=your-google-api-key
